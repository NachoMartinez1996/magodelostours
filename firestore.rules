rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.email == "ignaciomartinez21@hotmail.com";
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /agenda/{docId} {
      allow read: if resource.data.published == true || isAdmin();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        signedIn()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["booked", "spots", "updatedAt"])
        && request.resource.data.booked is int
        && request.resource.data.booked > resource.data.booked
        && (!resource.data.keys().hasAny(["capacity"]) || resource.data.capacity == 0 || request.resource.data.booked <= resource.data.capacity)
      );
    }

    match /siteConfig/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /reviews/{docId} {
      allow read: if resource.data.approved == true || isAdmin() || (signedIn() && resource.data.uid == request.auth.uid);
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /suggestions/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /registrations/{docId} {
      allow create: if true;
      allow read: if isAdmin() || (signedIn() && resource.data.uid == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow create: if signedIn() && request.auth.uid == userId;
      allow read, update: if isAdmin() || isOwner(userId);
      allow delete: if isAdmin();
    }

    match /leaderboard_memory/{docId} {
      allow read: if true;
      allow create: if signedIn();
      allow update, delete: if isAdmin();
    }

    match /leaderboard_challenge/{docId} {
      allow read: if true;
      allow create: if signedIn();
      allow update, delete: if isAdmin();
    }
  }
}
